# ==============================================================================
# PENGATURAN LINGKUNGAN APLIKASI (FRONTEND - NEXT.JS)
# ==============================================================================
# PERHATIAN: 
# Variabel yang diawali dengan 'NEXT_PUBLIC_' akan terekspos ke sisi klien (Browser).
# Jangan pernah menaruh Secret Key, Password Database, atau JWT Secret di sini!

# 1. URL UTAMA WEBSITE (Frontend)
# Digunakan oleh layout.tsx dan sitemap.ts untuk keperluan SEO & Open Graph
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# 2. URL BACKEND API (Golang)
# Digunakan oleh lib/api.ts untuk berkomunikasi dengan server backend
NEXT_PUBLIC_API_URL="http://localhost:8080"

# ==============================================================================
# CATATAN UNTUK PRODUCTION:
# Saat deploy (misal ke Vercel atau VPS), pastikan Anda mengganti nilainya:
# NEXT_PUBLIC_SITE_URL="https://titiannusantara.com"
# NEXT_PUBLIC_API_URL="https://api.titiannusantara.com" ATAU "https://titiannusantara.com/api" 
# (Tergantung setup reverse proxy Nginx Anda nantinya)